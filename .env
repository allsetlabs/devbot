# DevBot Environment Variables
# Dynamic vars (API_KEY, VITE_API_KEY, DEVBOT_PROJECTS_DIR, BACKEND_PORT,
# BACKEND_HOST, VITE_BACKEND_PORT, VITE_DEVBOT_PROJECTS_DIR) are injected
# by `make start` as environment variables — not written to this file.

# SQLite Database Paths
DB_CORE_PATH=~/.devbot/devbot.db
DB_BABY_LOGS_PATH=~/.devbot/baby-logs.db
DB_LAWN_CARE_PATH=~/.devbot/lawn-care.db

# Terminal port ranges
XTERM_BASE_PORT=7750
XTERM_MAX_PORT=7799
