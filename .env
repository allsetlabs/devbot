# DevBot Environment Variables

# Backend API Key (set by Makefile on start)
# API_KEY - set dynamically

# ttyd Configuration
TTYD_BASE_PORT=7681
TTYD_MAX_PORT=7700
# TTYD_CREDENTIAL=devbot:devbot123  # Disabled for development

# Claude Code working directory (set by Makefile on start)
# CLAUDE_WORK_DIR - set dynamically

# Backend server port (set by Makefile on start)
# BACKEND_PORT - set dynamically
# BACKEND_HOST - set dynamically

# SQLite Database Paths
DB_CORE_PATH=~/.devbot/devbot.db
DB_BABY_LOGS_PATH=~/.devbot/baby-logs.db
DB_LAWN_CARE_PATH=~/.devbot/lawn-care.db

# Terminal port ranges
XTERM_BASE_PORT=7750
XTERM_MAX_PORT=7799
MOSH_BASE_PORT=60001
MOSH_MAX_PORT=60050
MOSH_BRIDGE_BASE_PORT=7850
MOSH_BRIDGE_MAX_PORT=7899

# Frontend configuration (set by Makefile on start)
# VITE_BACKEND_PORT - set dynamically
# VITE_API_KEY - set dynamically
