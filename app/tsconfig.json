{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "types": ["vite/client"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@allsetlabs/reusable/*": ["../reusables/src/*"],
      "@devbot/app/*": ["./src/*"],
      "@devbot/plugin-baby-logs/frontend/*": ["../plugins/baby-logs/frontend/*"],
      "@devbot/plugin-baby-logs/backend/*": ["../plugins/baby-logs/backend/*"],
      "@devbot/plugin-lawn-care/frontend/*": ["../plugins/lawn-care/frontend/*"],
      "@devbot/plugin-lawn-care/backend/*": ["../plugins/lawn-care/backend/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
