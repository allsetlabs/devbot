{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "types": ["vite/client"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@subbiah/reusable/*": ["../../component/src/*"],
      "@devbot/app/*": ["./src/*"],
      "@devbot/plugin-baby-logs/frontend": ["../plugins/baby-logs/frontend/index.ts"],
      "@devbot/plugin-baby-logs": ["../plugins/baby-logs/backend/index.ts"],
      "@devbot/plugin-lawn-care/frontend": ["../plugins/lawn-care/frontend/index.ts"],
      "@devbot/plugin-lawn-care": ["../plugins/lawn-care/backend/index.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
